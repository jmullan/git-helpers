#!/bin/bash

set -euo pipefail
if date -d '1970-01-01' +%s >/dev/null 2>&1; then
    DATE_STYLE="gnu"
else
    DATE_STYLE="bsd"
fi

default_branch="origin/main"

if [ "${DATE_STYLE}" = "gnu" ]; then
    cutoff_date=$(date -d '1 year ago' +%s)
else
    cutoff_date=$(date -v -1y +%s)
fi

git fetch --all --prune

for branch in $(git for-each-ref --format='%(refname:short)' refs/remotes/origin | grep -vE "HEAD|main|master"); do
    last_commit_epoch=$(git log -1 --format='%ct' "${branch}" || echo 0)
    if [ "${last_commit_epoch}" -lt "${cutoff_date}" ]; then
        behind=$(git rev-list --count "${branch}..${default_branch}")

        if [ "${behind}" -gt 100 ]; then
            if [ "${DATE_STYLE}" = "gnu" ]; then
                last_commit_date=$(date -d @"${last_commit_epoch}" +%Y-%m-%d)
            else
                last_commit_date=$(date -r "${last_commit_epoch}" +%Y-%m-%d)
            fi
            echo "${branch} (behind: ${behind} commits, last update: ${last_commit_date}"
        fi
    fi
done
